{
  "name": "skillnode",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "build": "npm run build -w client && npm run prisma:generate -w server",
    "build:client": "npm run build -w client",
    "db:push": "npm run prisma:push -w server",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server"
  }
}

